{
  "name": "gutlog",
  "version": "0.1.0",
  "private": true,
  "description": "Local first PWA that logs meals and symptoms, then runs statistical analysis to find food/symptom correlations.",
  "author": "Zanden Kane",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dexie": "^4.0.11",
    "preact": "^10.25.4"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.3",
    "fake-indexeddb": "^6.0.0",
    "happy-dom": "^16.6.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^3.0.4",
    "workbox-precaching": "^7.3.0"
  }
}
